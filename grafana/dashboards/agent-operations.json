  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "agent",
        "label": "Agent",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(agent_run_total, agent)",
          "refId": "agent"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(llm_calls_total, model)",
          "refId": "model"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "prompt_cost",
        "label": "Prompt $/1K tokens",
        "type": "constant",
        "query": "0.00015",
        "current": {
          "text": "0.00015",
          "value": "0.00015"
        },
        "hide": 0
      },
      {
        "name": "completion_cost",
        "label": "Completion $/1K tokens",
        "type": "constant",
        "query": "0.00060",
        "current": {
          "text": "0.00060",
          "value": "0.00060"
        },
        "hide": 0
      }
    ]
